@using Craft.Domain
@using Craft.UiBuilders.Components.RunningNumber
@using Craft.UiBuilders.Generic
@using Craft.UiComponents
@using Craft.UiComponents.Semantic

@typeparam TEntity where TEntity : class, IEntity, IModel, new()

@inherits CraftComponent

<CraftDashBoardCard Icon="@Icon" Title="@Title" Href="@(_href)">
	<CraftDiv Class="d-flex justify-center align-center">
		<DataLoader IsLoading="@_isLoading" HasError="@_hasError">
			<Error>
				<CraftDiv Class="d-flex flex-column align-center gap-2">
					<MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
					<MudText Typo="Typo.caption" Color="Color.Error">Failed to load</MudText>
				</CraftDiv>
			</Error>
			<ChildContent>
				<MudText Typo="Typo.h3" Color="Color.Primary">
					<CraftRunningNumber FirstNumber="0" LastNumber="@_count" TotalTime="@AnimationDuration" 
						UseSmoothEasing="true" />
				</MudText>
			</ChildContent>
		</DataLoader>
	</CraftDiv>
</CraftDashBoardCard>
