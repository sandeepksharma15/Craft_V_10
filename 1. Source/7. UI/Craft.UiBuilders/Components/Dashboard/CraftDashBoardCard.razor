@using Craft.UiBuilders.Generic
@using Craft.UiComponents
@using Craft.UiComponents.Semantic

@inherits CraftComponent

<Show When="@(Visible)">
    <MudPaper Elevation="@_currentElevation" Class="pa-3 cursor-pointer transition-all" Style="height: 100%;"
              @onmouseenter="OnMouseEnter" @onmouseleave="OnMouseLeave">

        <MudGrid Spacing="3" Style="height: 100%;">
            <!-- Title Area -->
            <MudItem xs="12" Class="flex-grow-1">
                <MudText Typo="Typo.caption">@Title</MudText>
            </MudItem>

            <!-- Large Icon on Left -->
            <MudItem xs="3" Class="flex-grow-1">
                <CraftDiv class="d-flex justify-center align-center">
                    <MudIcon Icon="@Icon" Color="Color.Primary" Size="Size.Large" Style="font-size: 4rem;" />
                </CraftDiv>
            </MudItem>

            <!-- Child Content on Right -->
            <MudItem xs="9" Class="flex-grow-1">
                <CraftDiv Class="flex-grow-1">
                    @ChildContent
                </CraftDiv>
            </MudItem>

            <!-- More Info Link at Bottom -->
            <MudItem xs="12" Class="d-flex justify-end align-center">
                <MudLink Href="@Href" Color="Color.Primary" Class="d-flex align-center gap-1">
                    <MudText Typo="Typo.body2">More Info</MudText>
                    <MudIcon Icon="@MoreInfoIcon" Size="Size.Small" />
                </MudLink>
            </MudItem>
        </MudGrid>
    </MudPaper>
</Show>
