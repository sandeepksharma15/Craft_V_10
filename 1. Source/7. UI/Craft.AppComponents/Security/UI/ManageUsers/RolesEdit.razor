@namespace Craft.AppComponents.Security
@using Craft.Components.Generic
@using Craft.Security
@using Craft.UiBuilders.Generic
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@typeparam TRole where TRole : class, ICraftRole, new()
@typeparam TRoleVM where TRoleVM : class, ICraftRole, new()
@typeparam TRoleDTO where TRoleDTO : class, ICraftRole, new()

<DataLoader IsLoading="@(_viewModel is null)">
    <EditForm Model="@_viewModel" OnValidSubmit="HandleSubmitAsync">
        <DataAnnotationsValidator />
        <CustomValidator @ref="_customValidator" />

        <MudGrid>
            <Show When="@(_customValidator!.HasErrors)">
                <MudItem xs="12" Class="pt-4">
                    <MudPaper Class="px-2 pt-3 pb-1">
                        <ValidationSummary />
                    </MudPaper>
                </MudItem>
            </Show>

            <MudItem xs="12">
                <MudCard>
                    <MudCardContent>
                        <MudTextField @bind-Value="_viewModel!.Name" Label="Name" For="@(() => _viewModel!.Name)"
                                      Required="true" Immediate="true" Class="mb-3" Variant="Variant.Outlined" ReadOnly="@IsViewMode" />
                        <MudTextField @bind-Value="_viewModel!.Description" Label="Description" For="@(() => _viewModel!.Description)"
                                      Immediate="true" Class="mb-3" Variant="Variant.Outlined" ReadOnly="@IsViewMode" />
                        <MudSwitch @bind-Value="_viewModel!.IsActive" Label="Active" Color="Color.Primary" Disabled="@IsViewMode" Class="mb-3" />
                    </MudCardContent>
                    <MudCardActions Class="pa-3">
                        <Show When="@(!IsViewMode)">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-1">Save</MudButton>
                        </Show>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="HandleCancelAsync" Class="ml-3">@(IsViewMode ? "Back" : "Cancel")</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
</DataLoader>

<Spinner Visible="@_isSpinnerVisible" />
