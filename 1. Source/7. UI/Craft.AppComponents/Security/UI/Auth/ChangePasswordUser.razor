@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor

@namespace Craft.AppComponents.Security

@typeparam TUser where TUser : class

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 80vh;">
    <MudCard Class="mx-auto" Style="width: 100%; max-width: 440px;" Elevation="4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center">@Title</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            @if (_submitted)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-4">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                             Color="Color.Success"
                             Style="font-size: 3rem;" />
                    <MudText Typo="Typo.h6" Align="Align.Center">Password changed!</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center">
                        Your password has been updated successfully.
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(ReturnHref))
                    {
                        <MudButton Href="@ReturnHref"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Class="mt-2">
                            Continue
                        </MudButton>
                    }
                </MudStack>
            }
            else
            {
                <EditForm Model="@_model" OnValidSubmit="HandleChangePasswordAsync">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.CurrentPassword"
                                  Label="Current Password"
                                  InputType="InputType.Password"
                                  For="@(() => _model.CurrentPassword)"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.NewPassword"
                                  Label="New Password"
                                  InputType="@_newPasswordInputType"
                                  For="@(() => _model.NewPassword)"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  Immediate="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_newPasswordIcon"
                                  OnAdornmentClick="ToggleNewPasswordVisibility" />

                    <MudTextField @bind-Value="_model.ConfirmNewPassword"
                                  Label="Confirm New Password"
                                  InputType="InputType.Password"
                                  For="@(() => _model.ConfirmNewPassword)"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  Immediate="true" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Disabled="@_isProcessing"
                               Class="mb-3">
                        @if (_isProcessing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Changing…</span>
                        }
                        else
                        {
                            <span>Change Password</span>
                        }
                    </MudButton>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(ReturnHref))
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.body2" Align="Align.Center">
                        <MudLink Href="@ReturnHref">Cancel</MudLink>
                    </MudText>
                }
            }
        </MudCardContent>
    </MudCard>
</MudContainer>
