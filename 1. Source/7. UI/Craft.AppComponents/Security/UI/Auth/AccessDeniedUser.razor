@using Craft.UiBuilders.SVGs
@using MudBlazor

@namespace Craft.AppComponents.Security

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 80vh;">
    <MudCard Class="mx-auto" Style="width: 100%; max-width: 480px;" Elevation="4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h4" Align="Align.Center">@Title</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent Class="d-flex flex-column align-center">
            <Draw403 />
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mt-3">
                You do not have permission to access this page.
            </MudText>
        </MudCardContent>

        <MudCardActions>
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="w-100 pb-2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Home"
                           Href="@HomeHref">
                    Go Home
                </MudButton>

                @if (!string.IsNullOrWhiteSpace(LoginHref))
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.SwitchAccount"
                               Href="@LoginHref">
                        Sign in with a different account
                    </MudButton>
                }
            </MudStack>
        </MudCardActions>
    </MudCard>
</MudContainer>
