@using System.Security.Claims
@using Craft.Security
@using Craft.UiBuilders.Generic
@using MudBlazor

@namespace Craft.AppComponents.Security

@typeparam TUser where TUser : class

@if (_isAuthenticated)
{
    <MudNavGroup Title="@_displayName" Icon="@UserGroupIcon" Expanded="false">
        @if (!string.IsNullOrWhiteSpace(ChangePasswordHref))
        {
            <MudNavLink Href="@ChangePasswordHref" Icon="@ChangePasswordIcon">Change Password</MudNavLink>
        }
        <MudNavLink Icon="@LogoutIcon" OnClick="HandleLogoutAsync" Disabled="@_isProcessing">
            <Spinner Visible="@_isProcessing" />
            Logout
        </MudNavLink>
    </MudNavGroup>
}
else
{
    <MudNavLink Href="@LoginHref" Icon="@LoginIcon">Login</MudNavLink>
    <MudNavLink Href="@RegisterHref" Icon="@RegisterIcon">Register</MudNavLink>
}
